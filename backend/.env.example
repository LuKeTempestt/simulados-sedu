# Copie este arquivo para `.env` (sem o .example) e troque [SUA_SENHA] pela
# senha do banco (Database Password) do projeto Supabase.
# O `.env` e ignorado pelo git, entao a senha nao vaza.

# ---- OPCAO 1: Direct connection (use se sua rede tem IPv6) ----
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.yupfdhxzikkfsuvualyx.supabase.co:5432/postgres

# ---- OPCAO 2: Session pooler (IPv4, gratis) ----
# Se a Opcao 1 nao conectar, comente a linha acima e use esta.
# DATABASE_URL=postgresql://postgres.yupfdhxzikkfsuvualyx:[SUA_SENHA]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# Chave para assinar tokens JWT (qualquer string longa e aleatoria).
SEDU_JWT_SECRET=troque-esta-chave-por-algo-aleatorio-bem-longo
