# Configuração da aplicação SEDUC Simulados.
# Copie este arquivo para `.env` (que NÃO vai para o git) e ajuste os valores.

# Ambiente: desenvolvimento | producao
SEDU_AMBIENTE=desenvolvimento

# Segredo do JWT. OBRIGATÓRIO em produção (a app recusa subir com placeholder).
# Gere um forte com:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SEDU_JWT_SECRET=cole-aqui-um-segredo-forte

# Validade do token em horas.
SEDU_JWT_EXPIRA_HORAS=8

# Banco de dados. SQLite no dev; em produção use PostgreSQL, ex.:
#   postgresql+psycopg://usuario:senha@localhost:5432/seduc_simulados
# SEDU_DATABASE_URL=sqlite:///seduc_questoes.db

# Origens permitidas no CORS (separadas por vírgula). Em produção, restrinja ao domínio real.
SEDU_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Habilita a página de demonstração e o seed de demonstração. Deixe false em produção.
SEDU_DEMO_HABILITADO=true
