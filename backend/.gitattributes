# Normaliza fim de linha: evita ruído de CRLF/LF entre máquinas e entre os dois
# repositórios que hospedam este backend. Diffs reais voltam a ficar legíveis.
* text=auto eol=lf

# Arquivos binários não devem ser normalizados.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.db binary
*.sqlite binary
*.sqlite3 binary
