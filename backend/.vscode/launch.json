{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug API SEDUC (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.api.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "console": "integratedTerminal",
      "justMyCode": true,
      "cwd": "${workspaceFolder}",
      "env": { "PYTHONIOENCODING": "utf-8" }
    }
  ]
}
