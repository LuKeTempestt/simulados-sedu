# .env da RAIZ - usado por scripts/start-app.ps1, docker-compose e rotas BFF.
#
# Sem DATABASE_URL, scripts/start-app.ps1 sobe o Postgres local Docker como
# fallback. Com DATABASE_URL válido, o backend usa Supabase e mantém o banco
# local parado.

# DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.yupfdhxzikkfsuvualyx.supabase.co:5432/postgres
# SEDU_JWT_SECRET=troque-por-algo-aleatorio

# Para desenvolvimento fora do Docker, o frontend chama o backend local.
# No Docker, docker-compose injeta http://backend:8000 automaticamente.
# BACKEND_URL=http://localhost:8000
